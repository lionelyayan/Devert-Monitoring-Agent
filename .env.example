# =============================================================
# Devert Monitor Agent — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# ────────────────────────────────────────────────────────────
# GitHub Container Registry (GHCR) — untuk docker-compose.prod.yml
# ────────────────────────────────────────────────────────────
GITHUB_USERNAME=lionelyayan
GITHUB_REPO=devert-monitoring-agent
# Tag image yang digunakan: latest, v1.2.3, main-abc1234
IMAGE_TAG=v1.0.3

# ────────────────────────────────────────────────────────────
# Server Identity
# ────────────────────────────────────────────────────────────
SERVER_NAME=server-a
TIMEZONE=Asia/Jakarta

# ────────────────────────────────────────────────────────────
# HTTP API
# ────────────────────────────────────────────────────────────
HTTP_PORT=8080

# Static Bearer token for API authentication
# Generate with: openssl rand -hex 32
API_TOKEN=30ae68b3a127eb59e0bf25cdd154eacf168dc07813116db824d1114b3a188955

# Rate limit: requests per minute per IP
RATE_LIMIT_RPM=100

# ────────────────────────────────────────────────────────────
# PostgreSQL
# ────────────────────────────────────────────────────────────
POSTGRES_DSN=postgres://n8n:password123@postgres:5432/devert_monitor?sslmode=disable

# ────────────────────────────────────────────────────────────
# Docker
# ────────────────────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock

# ────────────────────────────────────────────────────────────
# n8n Webhook
# ────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=http://n8n.devert.internal/webhook/docker-events
N8N_WEBHOOK_SECRET=
# Set to false to disable webhook forwarding
N8N_WEBHOOK_ENABLED=true
# Webhook hanya dikirim untuk event error/critical:
# die, oom, kill, stop, pause, destroy, health_status:unhealthy

# ────────────────────────────────────────────────────────────
# Logging
# ────────────────────────────────────────────────────────────
# Levels: debug, info, warn, error
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────
# Monitoring Intervals (seconds)
# ────────────────────────────────────────────────────────────
SERVER_POLL_INTERVAL=30
RESOURCE_POLL_INTERVAL=10
SERVICE_POLL_INTERVAL=60
